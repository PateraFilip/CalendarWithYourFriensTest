# Zkopíruj hodnoty z Supabase Dashboard → Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web push (Firebase Cloud Messaging → Cloud Messaging → Web Push certificates)
EXPO_PUBLIC_FIREBASE_VAPID_KEY=your-web-push-vapid-key

# Edge Function send-notification (volitelné; Database Webhook header x-webhook-secret)
# NOTIFICATION_WEBHOOK_SECRET=long-random-secret
